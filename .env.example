# Claude-bot env template — copy to .env and fill in

# REQUIRED: Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=PASTE_...RE

# REQUIRED: MiniMax API key (Anthropic-format, api.minimax.io)
MINIMAX_API_KEY=*** your-anthropic-key-here
# Defaults: model=highspeed, 8000 max_tokens
# MINIMAX_MODEL=MiniMax-M2.7-highspeed
# MIN_TOKENS=8000

# OPTIONAL: TTS
TTS_ENABLED=true
TTS_VOICE=English_Graceful_Lady

# OPTIONAL: whisper for voice messages (MiniMax has no STT)
# Set EITHER of these to enable /voice handling
# WHISPER_API_KEY=sk-...
# OPENAI_API_KEY=sk-...

# OPTIONAL: silence timeout before summarizer fires
STREAM_TIMEOUT=10

# OPTIONAL: claude CLI override
# CLAUDE_COMMAND=/usr/local/bin/claude
