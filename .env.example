# Claude-bot env template — copy to .env and fill in

# REQUIRED: Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=PASTE_...RE

# REQUIRED: MiniMax API key (Anthropic-format, api.minimax.io)
MINIMAX_API_KEY=*** your-anthropic-key-here
# Defaults: model=highspeed, 8000 max_tokens
# MINIMAX_MODEL=MiniMax-M2.7-highspeed
# MIN_TOKENS=8000

# OPTIONAL: TTS
TTS_ENABLED=true
TTS_VOICE=English_Graceful_Lady

# OPTIONAL: voice transcription
# Default: local openai-whisper "tiny" model, imported from the hermes-agent venv
# at /home/Hermes/.hermes/hermes-agent/venv/ (whisper + torch already installed
# there from the practicepteonline pipeline). First run downloads tiny.pt (~75MB)
# to ~/.cache/whisper/. ~2.5s per 1s of audio on CPU. No key, no quota, private.
# Set WHISPER_LOCAL=0 to disable local and force API-only.
WHISPER_LOCAL=1
WHISPER_LOCAL_MODEL=tiny   # tiny|base|small|medium|large

# Optional fallback: if local whisper fails, fall back to OpenAI Whisper API.
# Set EITHER of these (WHISPER_API_KEY takes priority).
# WHISPER_API_KEY=sk-...
# OPENAI_API_KEY=sk-...

# OPTIONAL: silence timeout before summarizer fires
STREAM_TIMEOUT=10

# OPTIONAL: claude CLI override
# CLAUDE_COMMAND=/usr/local/bin/claude
